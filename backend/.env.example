# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Settings - PostgreSQL avec schéma dédié
DB_ENGINE=django.db.backends.postgresql
DB_NAME=portfolio
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432
DB_SCHEMA=trading_journal

# Alternative: SQLite pour développement simple
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# Configuration email (ex. Brevo)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-brevo-api-key
DEFAULT_FROM_EMAIL=noreply@kctradingjournal.com

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Redis & Celery Settings (requis en prod / simulation prod)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1
# Cache fichier de secours bandeau cours (si Redis indisponible) — prod : laisser défaut backend/var
# MARKET_QUOTES_DATA_DIR=/var/www/html/trading_journal/backend/var

# Intégrations API (secrets utilisateur chiffrés en base)
# INTEGRATIONS_CREDENTIALS_KEY=  # optionnel ; dérivé de SECRET_KEY si absent
# TOPSTEPX_API_BASE_URL=https://api.topstepx.com
# TOPSTEPX_API_TIMEOUT_SECONDS=10
# TOPSTEPX_RTC_MARKET_HUB_URL=https://rtc.topstepx.com/hubs/market
# Bandeau cours dashboard (abonnement API TopStep requis)
# TOPSTEPX_QUOTES_USERNAME=
# TOPSTEPX_QUOTES_API_KEY=

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PREMIUM_ID=price_xxx
