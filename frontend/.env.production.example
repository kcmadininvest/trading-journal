# Configuration d'environnement pour la production
# Copiez ce fichier vers .env.production et modifiez les valeurs selon votre environnement

# URL de base de l'application (sans trailing slash)
VITE_BASE_URL=https://your-domain.com

# URL de l'API backend
VITE_API_URL=https://your-domain.com/api

# Environnement
VITE_ENVIRONMENT=production

# Autres variables d'environnement pour la production (optionnelles)
# VITE_DEBUG=false
# VITE_VERSION=1.0.0
